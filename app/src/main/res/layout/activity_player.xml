<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_player_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/player_bg" />

    <!-- 播放器整体可滚动：首屏放封面和控制区，下滑后展示歌词。 -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv_player"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_first_screen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gl_safe_top"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.22" />

                <!-- 底部安全线：让按钮区和页面底部装饰保持距离。 -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gl_safe_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.92" />

                <!-- 顶部栏：返回按钮和播放状态提示。 -->
                <LinearLayout
                    android:id="@+id/ll_topbar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageButton
                        android:id="@+id/btn_exit"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_circle_glass_dark"
                        android:contentDescription="返回"
                        android:padding="8dp"
                        android:src="@drawable/ic_player_back"
                        app:tint="@android:color/white" />

                    <TextView
                        android:id="@+id/tv_top_hint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="正在播放"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp" />

                </LinearLayout>

                <!-- 唱片和封面区域：Java 代码会对封面做旋转、灰度等图片特效。 -->
                <FrameLayout
                    android:id="@+id/fl_disc"
                    android:layout_width="280dp"
                    android:layout_height="280dp"
                    android:layout_marginTop="10dp"
                    app:layout_constraintTop_toBottomOf="@id/gl_safe_top"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_record_disc" />

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_music"
                        android:layout_width="136dp"
                        android:layout_height="136dp"
                        android:layout_gravity="center"
                        android:scaleType="centerCrop"
                        android:src="@drawable/cover_miriam"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Full" />

                </FrameLayout>

                <!-- 歌曲信息区：播放器根据 songId 动态填充歌名和风格。 -->
                <LinearLayout
                    android:id="@+id/ll_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_card_dark"
                    android:orientation="vertical"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/fl_disc"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <TextView
                        android:id="@+id/tv_music_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="歌曲名"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_type"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="歌手 · 风格"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp" />

                </LinearLayout>

                <!-- 歌词提示：引导用户继续下滑查看 assets 中读取的歌词。 -->
                <TextView
                    android:id="@+id/tv_scroll_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="下滑查看歌词"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp"
                    app:layout_constraintTop_toBottomOf="@id/ll_info"
                    app:layout_constraintStart_toStartOf="@id/ll_info" />

                <!-- 播放进度区：SeekBar 会和 PlayerService 中的 MediaPlayer 进度同步。 -->
                <LinearLayout
                    android:id="@+id/ll_progress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical"
                    app:layout_constraintTop_toBottomOf="@id/tv_scroll_hint"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <SeekBar
                        android:id="@+id/sb"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp">

                        <TextView
                            android:id="@+id/tv_progress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="00:00"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="00:00"
                            android:textColor="#CCFFFFFF"
                            android:textSize="12sp" />

                    </RelativeLayout>

                </LinearLayout>

                <!-- 播放控制区：上一首、播放暂停、下一首都会调用 PlayerService。 -->
                <LinearLayout
                    android:id="@+id/ll_controls"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/ll_progress"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ImageButton
                        android:id="@+id/btn_play"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_glass_dark"
                        android:contentDescription="上一首"
                        android:padding="10dp"
                        android:src="@drawable/ic_player_prev"
                        app:tint="@android:color/white" />

                    <ImageButton
                        android:id="@+id/btn_pause"
                        android:layout_width="62dp"
                        android:layout_height="62dp"
                        android:layout_marginStart="18dp"
                        android:layout_marginEnd="18dp"
                        android:background="@drawable/bg_circle_glass_dark_main"
                        android:contentDescription="播放暂停"
                        android:padding="14dp"
                        android:src="@drawable/ic_player_play"
                        app:tint="@android:color/white" />

                    <ImageButton
                        android:id="@+id/btn_continue_play"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_glass_dark"
                        android:contentDescription="下一首"
                        android:padding="10dp"
                        android:src="@drawable/ic_player_next"
                        app:tint="@android:color/white" />

                </LinearLayout>

                <!-- 功能按钮区：一个演示图片特效，一个演示下载到本地后播放。 -->
                <Button
                    android:id="@+id/btn_cover_effect"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_btn_ghost_dark"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="封面特效：原图"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/ll_controls"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <Button
                    android:id="@+id/btn_download"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_btn_primary"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:text="下载到本地（下载页可播放）"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    app:layout_constraintTop_toBottomOf="@id/btn_cover_effect"
                    app:layout_constraintBottom_toBottomOf="@id/gl_safe_bottom"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- 歌词区：打开页面时不抢首屏空间，用户下滑后阅读完整歌词。 -->
            <LinearLayout
                android:id="@+id/ll_lyric_section"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="歌词"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tv_lyric"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:lineSpacingExtra="4dp"
                    android:text="歌词展示区"
                    android:textColor="@android:color/white"
                    android:textSize="15sp" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>
