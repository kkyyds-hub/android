<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_home_bg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/home_bg_moonmusic"
        android:scaleType="centerCrop"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 半透明遮罩：让复杂背景上的文字和列表更容易看清。 -->
    <View
        android:id="@+id/v_home_dim"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#59000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- 首页头部：说明当前列表是可播放、可下载的推荐歌曲入口。 -->
    <LinearLayout
        android:id="@+id/ll_home_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
        android:padding="14dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="推荐下载"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="@android:color/white"/>

        <TextView
            android:id="@+id/tv_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="精选曲目 · 点击即可播放(前三首可进行下载播放对应歌曲)"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF"/>

    </LinearLayout>

    <!-- 歌曲列表容器：HomeFragment 会给 ListView 设置 SongListAdapter。 -->
    <FrameLayout
        android:id="@+id/fl_home_list_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_card_dark"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/ll_home_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ListView
            android:id="@+id/lv_download_songs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@android:color/transparent"
            android:dividerHeight="10dp"
            android:scrollbars="none"/>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
