<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_nicholas_bg"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/player_bg" />

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000" />

    <!-- 谢霆锋专区主滚动页：集中展示网络推荐、定位歌单、WebView 详情入口和视频入口。 -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingTop="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- 专区头部：展示人物信息，进入页面时会做简单入场动画。 -->
            <LinearLayout
                android:id="@+id/ll_nicholas_hero"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_dark"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="14dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_nicholas_avatar"
                    android:layout_width="104dp"
                    android:layout_height="128dp"
                    android:background="#33000000"
                    android:padding="2dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/nicholas_artist_hero_2024"
                    app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="谢霆锋"
                        android:textColor="@android:color/white"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Nicholas Tse"
                        android:textColor="#CCFFFFFF"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="摇滚 · 粤语经典 · 现场能量"
                        android:textColor="#D9FFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="2dp"
                        android:text="从粤语经典到现场摇滚，挑一首适合此刻播放的谢霆锋。"
                        android:textColor="#99FFFFFF"
                        android:textSize="11sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 今日推荐区：网络 HTTP 推荐和定位歌单都在这个卡片中更新。 -->
            <LinearLayout
                android:id="@+id/ll_nicholas_score"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="今日锋味推荐"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_nicholas_features"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="从线上曲库挑一首，再让所在城市给歌单换个角度。"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp" />

                <LinearLayout
                    android:id="@+id/ll_nicholas_network_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_item_dark"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="12dp">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/iv_nicholas_network_cover"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/nicholas_album_viva"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_nicholas_network_tag"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="在线精选"
                            android:textColor="#FFD36B"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_nicholas_network_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="正在挑选今日推荐..."
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_nicholas_network_reason"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:lineSpacingExtra="2dp"
                            android:maxLines="2"
                            android:text="从线上曲库里挑一首适合现在播放的谢霆锋。"
                            android:textColor="#D9FFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_nicholas_network_source"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="7dp"
                            android:text="稍后呈现"
                            android:textColor="#99FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_nicholas_location_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_item_dark"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <TextView
                        android:id="@+id/tv_nicholas_location_tag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="感知定位 · 默认城市"
                        android:textColor="#CCFFFFFF"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tv_nicholas_location_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="香港经典入门歌单"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_nicholas_location_reason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:lineSpacingExtra="2dp"
                        android:maxLines="3"
                        android:text="暂时没有读取到设备位置，使用默认城市香港生成谢霆锋音乐推荐，适合作为课堂演示兜底。"
                        android:textColor="#D9FFFFFF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_nicholas_location_source"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="来源：本地默认推荐 · 本地兜底"
                        android:textColor="#99FFFFFF"
                        android:textSize="11sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btn_nicholas_network"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_btn_ghost_dark"
                        android:text="换一首推荐"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <Button
                        android:id="@+id/btn_nicholas_location"
                        android:layout_width="0dp"
                        android:layout_height="42dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_btn_ghost_dark"
                        android:text="定位歌单"
                        android:textColor="@android:color/white"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- 继续探索区：两个卡片分别跳转到 WebView 详情页和 VideoView 视频页。 -->
            <LinearLayout
                android:id="@+id/ll_nicholas_explore"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="继续探索"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="看他的音乐轨迹，也看一段真正的 Viva Live。"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/btn_nicholas_detail"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_item_dark"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="match_parent"
                            android:layout_height="92dp"
                            android:background="#33000000"
                            android:padding="3dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/nicholas_artist_profile"
                            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="艺人档案"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="时间线与代表作品"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <View
                        android:layout_width="8dp"
                        android:layout_height="1dp" />

                    <LinearLayout
                        android:id="@+id/btn_nicholas_video"
                        android:layout_width="0dp"
                        android:layout_height="160dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_item_dark"
                        android:clickable="true"
                        android:focusable="true"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="match_parent"
                            android:layout_height="92dp"
                            android:background="#33000000"
                            android:padding="3dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/nicholas_album_viva_live"
                            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="现场短片"
                            android:textColor="@android:color/white"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:text="Viva Live 演唱会"
                            android:textColor="#B3FFFFFF"
                            android:textSize="11sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- 专辑照片墙：横向滚动展示本地图片资源。 -->
            <LinearLayout
                android:id="@+id/ll_nicholas_albums"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="专辑照片墙"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:overScrollMode="never"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="118dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_item_dark"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="match_parent"
                                android:layout_height="102dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/nicholas_album_understand"
                                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="了解"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="118dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_item_dark"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="match_parent"
                                android:layout_height="102dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/nicholas_album_thanks_1999"
                                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="谢谢你的爱1999"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="118dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_item_dark"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="match_parent"
                                android:layout_height="102dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/nicholas_album_viva"
                                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Viva"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="118dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_item_dark"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="match_parent"
                                android:layout_height="102dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/nicholas_album_jade_butterfly"
                                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="玉蝴蝶"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <View
                            android:layout_width="10dp"
                            android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="118dp"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_item_dark"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <com.google.android.material.imageview.ShapeableImageView
                                android:layout_width="match_parent"
                                android:layout_height="102dp"
                                android:scaleType="centerCrop"
                                android:src="@drawable/nicholas_album_me"
                                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="7dp"
                                android:ellipsize="end"
                                android:maxLines="1"
                                android:text="Me"
                                android:textColor="@android:color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </HorizontalScrollView>

                <TextView
                    android:id="@+id/tv_nicholas_albums"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="从早期国语专辑到 Viva Live 前后的粤语作品，顺着封面听见不同阶段的谢霆锋。"
                    android:textColor="#CCFFFFFF"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/ll_nicholas_songs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="可播放试听歌单"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="点击歌曲进入播放页，音频为公开试听片段。"
                    android:textColor="#99FFFFFF"
                    android:textSize="12sp" />

                <ListView
                    android:id="@+id/lv_nicholas_songs"
                    android:layout_width="match_parent"
                    android:layout_height="430dp"
                    android:layout_marginTop="10dp"
                    android:divider="@android:color/transparent"
                    android:dividerHeight="10dp"
                    android:nestedScrollingEnabled="false"
                    android:scrollbars="none" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>
