<?xml version="1.0" encoding="utf-8"?>
<!-- 歌曲列表项模板，被首页、下载页、喜欢页和谢霆锋专区共用。SongListAdapter 会把每首歌的封面、歌名和歌手·专辑信息填入对应控件。 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="78dp"
    android:background="@drawable/bg_item_dark"
    android:padding="10dp">

    <!-- 歌曲封面，56dp 圆角图片。SongListAdapter 通过 song.getCoverResId() 设置图片资源。 -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/iv_cover"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:src="@drawable/cover_miriam"
        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.App.Corner.Medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- 歌名，超出一行时末尾省略号截断。 -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="歌名"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:textSize="15sp"
        app:layout_constraintStart_toEndOf="@id/iv_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/iv_cover"/>

    <!-- 歌手 · 专辑副标题，由 Song.getSubtitle() 方法生成。 -->
    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="歌手 · 专辑"
        android:textColor="#CCFFFFFF"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/iv_cover"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_title"/>

</androidx.constraintlayout.widget.ConstraintLayout>
