<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Soft outer disc -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#33000000"/>
        </shape>
    </item>

    <!-- Outer ring -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="oval">
            <stroke android:width="2dp" android:color="#44FFFFFF"/>
            <solid android:color="#11000000"/>
        </shape>
    </item>

    <!-- Inner radial highlight -->
    <item android:left="14dp" android:top="14dp" android:right="14dp" android:bottom="14dp">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="160dp"
                android:centerColor="#22000000"
                android:startColor="#22FFFFFF"
                android:endColor="#00000000"/>
        </shape>
    </item>

</layer-list>
